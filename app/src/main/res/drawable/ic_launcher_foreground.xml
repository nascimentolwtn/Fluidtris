<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        L-tetromino (16×16 blocks, 3 gap) — bounding box (37,22)→(72,76), centered at (54,49).
        Left column: x=37, rows at y=22, 41, 60. Right foot: x=56, y=60.
        Each block: rounded rect r=2 traced clockwise.

        Draw order: blocks first, then waves on top — bottom blocks appear partially submerged.
    -->

    <!-- Block 1 (top of left column) -->
    <path android:pathData="M39,22 h12 a2,2 0 0 1 2,2 v12 a2,2 0 0 1 -2,2 h-12 a2,2 0 0 1 -2,-2 v-12 a2,2 0 0 1 2,-2 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="37" android:startY="22"
                android:endX="53" android:endY="38">
                <item android:offset="0.0" android:color="#FF80DEEA"/>
                <item android:offset="1.0" android:color="#FF00838F"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:fillColor="#40FFFFFF"
        android:pathData="M39,22 h12 a2,2 0 0 1 2,2 v5 h-16 v-5 a2,2 0 0 1 2,-2 z"/>

    <!-- Block 2 (middle of left column) -->
    <path android:pathData="M39,41 h12 a2,2 0 0 1 2,2 v12 a2,2 0 0 1 -2,2 h-12 a2,2 0 0 1 -2,-2 v-12 a2,2 0 0 1 2,-2 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="37" android:startY="41"
                android:endX="53" android:endY="57">
                <item android:offset="0.0" android:color="#FF80DEEA"/>
                <item android:offset="1.0" android:color="#FF00838F"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:fillColor="#40FFFFFF"
        android:pathData="M39,41 h12 a2,2 0 0 1 2,2 v5 h-16 v-5 a2,2 0 0 1 2,-2 z"/>

    <!-- Block 3 (bottom-left) — bottom edge just touches water surface -->
    <path android:pathData="M39,60 h12 a2,2 0 0 1 2,2 v12 a2,2 0 0 1 -2,2 h-12 a2,2 0 0 1 -2,-2 v-12 a2,2 0 0 1 2,-2 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="37" android:startY="60"
                android:endX="53" android:endY="76">
                <item android:offset="0.0" android:color="#FF80DEEA"/>
                <item android:offset="1.0" android:color="#FF00838F"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:fillColor="#40FFFFFF"
        android:pathData="M39,60 h12 a2,2 0 0 1 2,2 v5 h-16 v-5 a2,2 0 0 1 2,-2 z"/>

    <!-- Block 4 (bottom-right foot) -->
    <path android:pathData="M58,60 h12 a2,2 0 0 1 2,2 v12 a2,2 0 0 1 -2,2 h-12 a2,2 0 0 1 -2,-2 v-12 a2,2 0 0 1 2,-2 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="56" android:startY="60"
                android:endX="72" android:endY="76">
                <item android:offset="0.0" android:color="#FF80DEEA"/>
                <item android:offset="1.0" android:color="#FF00838F"/>
            </gradient>
        </aapt:attr>
    </path>
    <path android:fillColor="#40FFFFFF"
        android:pathData="M58,60 h12 a2,2 0 0 1 2,2 v5 h-16 v-5 a2,2 0 0 1 2,-2 z"/>

    <!-- Back wave — crests (Q control y=75) reach ~y=78, just grazing block bottoms -->
    <path android:pathData="M0,81 Q13.5,75 27,81 Q40.5,87 54,81 Q67.5,75 81,81 Q94.5,87 108,81 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="78"
                android:endX="54" android:endY="108">
                <item android:offset="0.0" android:color="#FF1565C0"/>
                <item android:offset="1.0" android:color="#FF0D3B8E"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Front wave — lower, lighter blue, adds depth -->
    <path android:pathData="M0,86 Q27,80 54,86 Q81,92 108,86 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="83"
                android:endX="54" android:endY="108">
                <item android:offset="0.0" android:color="#FF0288D1"/>
                <item android:offset="1.0" android:color="#FF01579B"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Water ripples on surface, centered at x=54 (horizontal center of L foot) -->
    <path android:fillColor="#00000000"
        android:strokeColor="#6600E5FF"
        android:strokeWidth="1.2"
        android:pathData="M46,81 a8,3.5 0 0 0 16,0"/>
    <path android:fillColor="#00000000"
        android:strokeColor="#3300E5FF"
        android:strokeWidth="0.8"
        android:pathData="M41,81 a13,5 0 0 0 26,0"/>

</vector>
